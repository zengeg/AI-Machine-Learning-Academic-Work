import numpy as np

def linear_kernel(x1, x2):
    """
    Compute the linear kernel between two vectors.
    k(x1, x2) = x1.T @ x2
    
    Parameters:
        x1, x2: numpy arrays of shape (n_features,)
    Returns:
        float: The linear kernel value
    """
    return np.dot(x1, x2)

def polynomial_kernel(x1, x2, degree=3, coef0=1):
    """
    Compute the polynomial kernel between two vectors.
    k(x1, x2) = (x1.T @ x2 + coef0)^degree
    
    Parameters:
        x1, x2: numpy arrays of shape (n_features,)
        degree: int, default=3, the polynomial degree
        coef0: float, default=1, the constant term
    Returns:
        float: The polynomial kernel value
    """
    return (np.dot(x1, x2) + coef0) ** degree

def rbf_kernel(x1, x2, gamma=0.1):
    """
    Compute the Gaussian (RBF) kernel between two vectors.
    k(x1, x2) = exp(-gamma * ||x1 - x2||^2)
    
    Parameters:
        x1, x2: numpy arrays of shape (n_features,)
        gamma: float, default=0.1, the kernel bandwidth parameter
    Returns:
        float: The RBF kernel value
    """
    return np.exp(-gamma * (np.linalg.norm(x1 - x2) ** 2))

def sigmoid_kernel(x1, x2, alpha=0.1, coef0=0):
    """
    Compute the sigmoid kernel between two vectors.
    k(x1, x2) = tanh(alpha * (x1.T @ x2) + coef0)
    
    Parameters:
        x1, x2: numpy arrays of shape (n_features,)
        alpha: float, default=0.1, the scaling parameter
        coef0: float, default=0, the constant term
    Returns:
        float: The sigmoid kernel value
    """
    return np.tanh(alpha * np.dot(x1, x2) + coef0)
